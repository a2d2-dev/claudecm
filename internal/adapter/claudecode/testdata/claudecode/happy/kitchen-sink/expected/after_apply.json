{
  "env": {
    "ANTHROPIC_API_KEY": "sk-new-api",
    "ANTHROPIC_AUTH_TOKEN": "sk-new-auth",
    "ANTHROPIC_BASE_URL": "https://new.example.com",
    "ANTHROPIC_MODEL": "claude-haiku-4-5",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-tiny-fast",
    "CLAUDE_CODE_USE_BEDROCK": "0",
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CUSTOM_UNOWNED": "preserved"
  },
  "mcpServers": {
    "example": {
      "command": "node",
      "args": ["mcp.js"]
    }
  },
  "hooks": {
    "pre_apply": ["echo hi"]
  },
  "custom": {
    "nested": {
      "value": 42
    }
  },
  "permissions": {
    "allowed": ["fs", "net"]
  }
}
